# =============================================================================
# YouTube Viewer - Docker Compose Configuration
# =============================================================================
# Copy this file to .env and fill in your settings.
# Then run: docker-compose up -d
# Docker pulls both images from GHCR and creates all volumes automatically.
# No build steps, no cloning required — works with Arcane and plain CLI alike.
# =============================================================================

# --- YouTube Video URLs (comma-separated) ---
# Add one or more YouTube video URLs separated by commas.
# Example single URL:
#   YOUTUBE_URLS=https://www.youtube.com/watch?v=dQw4w9WgXcQ
# Example multiple URLs:
#   YOUTUBE_URLS=https://www.youtube.com/watch?v=dQw4w9WgXcQ,https://www.youtube.com/watch?v=abcdefghijk
YOUTUBE_URLS=https://www.youtube.com/watch?v=CHANGE_ME

# --- Tor Configuration ---
# Enable or disable Tor proxy (true/false)
TOR_ENABLED=true
# Starting port for Tor SOCKS proxies
TOR_START_PORT=9052

# --- YouTube Viewer Settings ---
# Number of parallel browser instances per batch
BATCH_COUNT=6
# Total number of view actions (should be divisible by BATCH_COUNT)
TOTAL_COUNT=96
# Number of videos watched per browser session
VIEW_ACTION_COUNT=10
# Average view duration in seconds (+/- 16.6% randomness)
VIEW_DURATION=50
# Max page timeout in seconds
PAGE_DEFAULT_TIMEOUT=600

# --- Image Tags ---
# Pin images to a specific version for reproducible deployments.
# Use a commit SHA tag (e.g. sha-a1b2c3d) or "latest" for the most recent build.
IMAGE_TAG=latest
TOR_IMAGE_TAG=latest

# --- Debug ---
# Set to true to enable debug logging
YOUTUBE_VIEWER_FORCE_DEBUG=false

# =============================================================================
# Newt Tunnel — OPTIONAL (default: disabled)
# =============================================================================
# Route ALL Tor exit traffic through an existing Newt tunnel container on this
# Docker host that is connected to your external VPS running Pangolin.
# When enabled, Tor builds circuits using the VPS as its internet uplink
# instead of the local server's IP.
#
# HOW TO ENABLE:
#   1. Set NEWT_TUNNEL_ENABLED=true below.
#   2. Fill in NEWT_TUNNEL_NETWORK and NEWT_TUNNEL_GATEWAY.
#   3. Deploy with the tunnel overlay:
#        docker-compose -f docker-compose.yml -f docker-compose.tunnel.yml up -d
#      Or in Arcane: merge docker-compose.tunnel.yml into the Compose field.
#   4. See README.md § "Newt Tunnel (optional)" for VPS / Pangolin setup.
# =============================================================================
# Enable tunnel routing (true/false)
NEWT_TUNNEL_ENABLED=false
# Docker network name that your Newt tunnel container is attached to
# (e.g. the network created by your Newt docker-compose stack)
NEWT_TUNNEL_NETWORK=
# IP address of the Newt tunnel container inside NEWT_TUNNEL_NETWORK
# Find it with: docker inspect <newt-container> | grep IPAddress
NEWT_TUNNEL_GATEWAY=
