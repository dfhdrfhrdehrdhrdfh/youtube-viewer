# =============================================================================
# YouTube Viewer - Docker Compose Configuration
# =============================================================================
# Copy this file to .env and fill in your settings.
# Then run: docker-compose up -d
# Docker pulls both images from GHCR and creates all volumes automatically.
# No build steps, no cloning required — works with Arcane and plain CLI alike.
# =============================================================================

# --- YouTube Video URLs (comma-separated) ---
# Add one or more YouTube video URLs separated by commas.
# Example single URL:
#   YOUTUBE_URLS=https://www.youtube.com/watch?v=dQw4w9WgXcQ
# Example multiple URLs:
#   YOUTUBE_URLS=https://www.youtube.com/watch?v=dQw4w9WgXcQ,https://www.youtube.com/watch?v=abcdefghijk
YOUTUBE_URLS=https://www.youtube.com/watch?v=CHANGE_ME

# --- Tor Configuration ---
# Enable or disable Tor proxy (true/false)
TOR_ENABLED=true
# Starting port for Tor SOCKS proxies
TOR_START_PORT=9052

# --- YouTube Viewer Settings ---
# Number of parallel browser instances per batch
BATCH_COUNT=6
# Total number of view actions (should be divisible by BATCH_COUNT)
TOTAL_COUNT=96
# Number of videos watched per browser session
VIEW_ACTION_COUNT=10
# Average view duration in seconds (+/- 16.6% randomness)
VIEW_DURATION=50
# Max page timeout in seconds
PAGE_DEFAULT_TIMEOUT=600

# --- Image Tags ---
# Pin images to a specific version for reproducible deployments.
# Use "latest" for the most recent stable build, "beta" for the latest beta build,
# or a commit SHA tag (e.g. sha-a1b2c3d) for exact pinning.
IMAGE_TAG=latest
TOR_IMAGE_TAG=latest

# --- Debug ---
# Set to true to enable debug logging
YOUTUBE_VIEWER_FORCE_DEBUG=false

# =============================================================================
# WireGuard VPS Tunnel — OPTIONAL (default: disabled)
# =============================================================================
# Route ALL Tor traffic through a WireGuard tunnel to your VPS.
# When enabled, a WireGuard container connects to your VPS and the Tor
# container routes all its traffic through the tunnel. Tor circuits are
# built using the VPS as the internet uplink instead of your local IP.
#
# HOW TO ENABLE:
#   1. Deploy the WireGuard receiver on your VPS first — see README.md for
#      the one-command setup. The output gives you the keys below.
#   2. Set TUNNEL_ENABLED=true.
#   3. Fill in VPS_IP, WG_SERVER_PUBLIC_KEY, and WG_CLIENT_PRIVATE_KEY.
#   4. Use docker-compose.tunnel.yml instead of docker-compose.yml:
#        Docker CLI:  docker-compose -f docker-compose.tunnel.yml up -d
#        Arcane:      Paste the contents of docker-compose.tunnel.yml
#                     (it is a complete standalone file — no merging needed).
# =============================================================================
# Enable WireGuard VPS tunnel (true/false)
TUNNEL_ENABLED=false

# Public IP address of your VPS (the IP you SSH into)
VPS_IP=
# WireGuard UDP port on VPS (default: 51821)
VPS_WG_PORT=51821
# WireGuard server public key (from VPS setup output)
WG_SERVER_PUBLIC_KEY=
# WireGuard client private key (from VPS setup output)
WG_CLIENT_PRIVATE_KEY=

# WireGuard tunnel client image tag
WG_IMAGE_TAG=latest
